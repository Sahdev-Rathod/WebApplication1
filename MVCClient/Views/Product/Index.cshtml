@model IEnumerable<MVCClient.Models.Product>

@{
    ViewBag.Title = "Index";
}

<style>
    :root {
        --accent: #6C63FF;
        --accent-2: #00C9A7;
        --muted: #6b7280;
        --bg: #f7fafc;
        --card: #ffffff;
    }

    .product-index {
        font-family: "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        color: #111827;
        padding: 20px;
        background: var(--bg);
    }

    .product-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
        gap: 12px;
    }

    .product-title {
        font-size: 1.6rem;
        font-weight: 600;
        color: var(--accent);
        margin: 0;
    }

    .create-btn {
        text-decoration: none;
        padding: 8px 14px;
        border-radius: 10px;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
        color: white;
        box-shadow: 0 6px 18px rgba(108, 99, 255, 0.18);
        border: none;
        font-weight: 600;
        display: inline-block;
    }

    .table-responsive {
        overflow-x: auto;
    }

    .styled-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        background: var(--card);
        box-shadow: 0 6px 18px rgba(15, 23, 42, 0.06);
        border-radius: 12px;
        overflow: hidden;
    }

    .styled-table thead th {
        background: linear-gradient(90deg, rgba(108, 99, 255, 0.12), rgba(0, 201, 167, 0.06));
        color: #0f172a;
        text-align: left;
        padding: 12px 16px;
        font-weight: 700;
        font-size: 0.95rem;
        border-bottom: 1px solid rgba(15, 23, 42, 0.06);
    }

    .styled-table tbody td {
        padding: 14px 16px;
        border-bottom: 1px solid rgba(15, 23, 42, 0.04);
        vertical-align: middle;
        color: #111827;
    }

    .styled-table tbody tr:nth-child(even) {
        background: linear-gradient(180deg, rgba(6, 95, 70, 0.01), transparent);
    }

    .styled-table tbody tr:hover {
        transform: translateY(-2px);
        background: rgba(99, 102, 241, 0.03);
        transition: all .15s ease;
    }

    .action-links a {
        text-decoration: none;
        margin-right: 6px;
        padding: 6px 10px;
        border-radius: 8px;
        font-size: 0.85rem;
        color: #fff;
        display: inline-block;
    }

    .btn { text-decoration: none; }

    .btn-primary { background: var(--accent); }
    .btn-info { background: #10b981; }
    .btn-danger { background: #ef4444; }

    .no-products td {
        padding: 18px;
        color: #ffffff;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
        text-align: center;
        font-weight: 700;
    }

    @media (max-width: 600px) {
        .product-title { font-size: 1.2rem; }
        .styled-table thead th, .styled-table tbody td { padding: 10px; }
        .create-btn { padding: 8px 10px; }
    }
</style>

<div class="product-index">
    <div class="product-header">
        <h2 class="product-title">Index</h2>
        @Html.ActionLink("Create New", "Create", null, new { @class = "create-btn" })
    </div>

    <div class="table-responsive">
        <table class="styled-table">
            <thead>
                <tr>
                    <th>
                        @Html.DisplayNameFor(model => model.Name)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Price)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Stock)
                    </th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.Name)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Price)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Stock)
                            </td>
                            <td class="action-links">
                                @Html.ActionLink("Edit", "Edit", new { id = item.Id }, new { @class = "btn btn-primary" })
                                @Html.ActionLink("Details", "Details", new { id = item.Id }, new { @class = "btn btn-info" })
                                @Html.ActionLink("Delete", "Delete", new { id = item.Id }, new { @class = "btn btn-danger" })
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr class="no-products">
                        <td colspan="4">No products available.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
