@model MVCClient.Models.Product

@{
    ViewBag.Title = "Edit Product";
}

<style>
    /* Scoped styles for a cleaner, modern look while remaining compatible with Bootstrap 3 */
    .edit-panel {
        max-width: 720px;
        margin: 30px auto;
        border-radius: 6px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .edit-panel .panel-heading {
        background: linear-gradient(90deg, #2c7be5, #2680eb);
        color: #fff;
        padding: 18px 20px;
        border: none;
    }

    .edit-panel .panel-title {
        margin: 0;
        font-size: 1.25rem;
        font-weight: 600;
    }

    .edit-panel .panel-body {
        background: #fff;
        padding: 20px;
    }

    .form-group .input-group-addon {
        background: #f5f7fb;
        border: 1px solid #ddd;
    }

    .help-block.text-danger {
        margin-top: 6px;
        display: block;
    }

    .btn-save {
        background: #28a745;
        border-color: #28a745;
        color: #fff;
    }

    .btn-cancel {
        background: transparent;
        border: 1px solid #ced4da;
        color: #495057;
    }

    /* Make validation summary look like an alert */
    .validation-alert {
        margin-bottom: 18px;
    }

    @media (max-width: 767px) {
        .control-label {
            text-align: left !important;
            margin-bottom: 6px;
        }
    }
</style>

<div class="edit-panel panel panel-default">
    <div class="panel-heading">
        <h3 class="panel-title">@ViewBag.Title</h3>
    </div>

    <div class="panel-body">
        <p class="text-muted">Update product details. Fields marked with * are required.</p>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()

            @* Validation summary shown as alert *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger validation-alert" role="alert">
                    @Html.ValidationSummary(true, "Please correct the errors and try again.", new { @class = "text-danger", @role = "alert" })
                </div>
            }

            @Html.HiddenFor(model => model.Id)

            <div class="form-horizontal">
                <div class="form-group">
                    @Html.LabelFor(model => model.Name, htmlAttributes: new { @class = "control-label col-md-3" })
                    <div class="col-md-9">
                        <div class="input-group">
                            <span class="input-group-addon">
                                <span class="glyphicon glyphicon-tag" aria-hidden="true"></span>
                            </span>
                            @Html.TextBoxFor(model => model.Name, new { @class = "form-control", placeholder = "Enter product name", autocomplete = "off" })
                        </div>
                        @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger help-block" })
                    </div>
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.Price, htmlAttributes: new { @class = "control-label col-md-3" })
                    <div class="col-md-9">
                        <div class="input-group">
                            <span class="input-group-addon">$</span>
                            @Html.EditorFor(model => model.Price, new { htmlAttributes = new { @class = "form-control", placeholder = "0.00", type = "number", step = "0.01", min = "0" } })
                        </div>
                        @Html.ValidationMessageFor(model => model.Price, "", new { @class = "text-danger help-block" })
                    </div>
                </div>

                <div class="form-group">
                    @Html.LabelFor(model => model.Stock, htmlAttributes: new { @class = "control-label col-md-3" })
                    <div class="col-md-9">
                        <div class="input-group">
                            <span class="input-group-addon">
                                <span class="glyphicon glyphicon-briefcase" aria-hidden="true"></span>
                            </span>
                            @Html.EditorFor(model => model.Stock, new { htmlAttributes = new { @class = "form-control", placeholder = "Quantity in stock", type = "number", min = "0" } })
                        </div>
                        @Html.ValidationMessageFor(model => model.Stock, "", new { @class = "text-danger help-block" })
                    </div>
                </div>

                <div class="form-group" style="margin-top:18px;">
                    <div class="col-md-offset-3 col-md-9">
                        <div class="row">
                            <div class="col-xs-6">
                                <input type="submit" value="Save Changes" class="btn btn-save btn-block" />
                            </div>
                            <div class="col-xs-6">
                                @Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-cancel btn-block", role = "button" })
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <hr />

        <div class="text-center">
            @Html.ActionLink("Back to Product List", "Index", null, new { @class = "btn btn-link" })
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
